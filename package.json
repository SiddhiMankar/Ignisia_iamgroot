{
  "name": "ignisia-monorepo",
  "version": "1.0.0",
  "description": "Ignisia Handwritten Document Intelligence Pipeline",
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:ai": "cd ai-engine && python main.py",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:ai\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
